# Copia este archivo a .env y rellena los valores.
# cp .env.example .env

# -----------------------------------------------------------------------------
# Base de datos — una de las dos formas (igual en local y producción):
# 1) DATABASE_URL (URL completa)
# 2) DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD (se construye la URL)
# -----------------------------------------------------------------------------

# Forma 1: URL completa (ej. local)
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/ct4
DATABASE_URL=postgresql://postgres@localhost:5432/ct4

# Forma 2: Variables separadas (si no usas DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ct4
# DB_USER=postgres
# DB_PASSWORD=

# Entorno: development | production
ENVIRONMENT=development

# CORS: "*" en desarrollo; en producción lista de orígenes separados por comas
CORS_ORIGINS=*

# Opcional: token para rutas de administración
# ADMIN_TOKEN=

# -----------------------------------------------------------------------------
# Producción (servidor 5.161.229.77)
#   Backend (API):  https://ct4.yego.pro
#   Frontend (UI):  https://api-ct4.yego.pro
#
# Ejemplo en producción con variables separadas (igual que en local):
#   DB_HOST=168.119.226.236
#   DB_PORT=5432
#   DB_NAME=yego_integral
#   DB_USER=yego_user
#   DB_PASSWORD=tu_contraseña
#   ENVIRONMENT=production
#   CORS_ORIGINS=https://api-ct4.yego.pro
# -----------------------------------------------------------------------------
