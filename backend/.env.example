# Copia este archivo a .env y rellena los valores.
# cp .env.example .env

# Base de datos (obligatorio para que la app conecte)
# Local: postgresql://usuario@localhost:5432/ct4
# Con contraseña: postgresql://usuario:contraseña@localhost:5432/ct4
# Remoto: postgresql://usuario:contraseña@host:5432/nombre_bd
DATABASE_URL=postgresql://postgres@localhost:5432/ct4

# Entorno: development | production
ENVIRONMENT=development

# CORS: "*" en desarrollo; en producción lista de orígenes separados por comas
CORS_ORIGINS=*

# Opcional: token para rutas de administración
# ADMIN_TOKEN=
